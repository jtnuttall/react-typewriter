{
  "name": "@jtnuttall/react-typewriter",
  "version": "1.0.0",
  "license": "BSD-3-Clause",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "test": "vitest",
    "typecheck": "tsgo -p tsconfig.json",
    "size": "size-limit",
    "prepare": "husky"
  },
  "dependencies": {
    "tiny-invariant": "^1.3.3"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^12.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260405.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.19.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "size-limit": "^12.0.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "size-limit": [
    {
      "path": "./dist/index.js",
      "limit": "2 kB"
    },
    {
      "path": "./dist/index.cjs",
      "limit": "2 kB"
    }
  ]
}
